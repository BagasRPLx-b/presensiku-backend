# ============================================================
# PRESENSI KU — Environment Variables (Contoh)
# Salin file ini menjadi .env dan sesuaikan nilainya
# ============================================================

# Server
PORT=3000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=presensi_ku

# Secret key untuk generate token QR harian
# Ganti dengan string rahasia yang kuat di production!
QR_SECRET_KEY=GANTI_DENGAN_SECRET_KEY_ANDA
